{
  "manifest_version": 3,
  "name": "Yellow.ai Email Logger",
  "version": "2.0",
  "description": "Auto-logs Resolved / On Hold tickets from Yellow.ai to your Email Log Sheet",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.firebaseio.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://cloud.yellow.ai/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://cloud.yellow.ai/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}
